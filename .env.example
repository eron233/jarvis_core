JARVIS_ENV=production
JARVIS_TOKEN=defina_um_token_seguro
JARVIS_TRUSTED_DEVICE_ID=eron-celular-principal
JARVIS_API_HOST=0.0.0.0
JARVIS_API_PORT=8000
JARVIS_LOOP_INTERVAL_SECONDS=5
JARVIS_IDLE_SLEEP_SECONDS=10
JARVIS_LOG_LEVEL=INFO
JARVIS_ENABLE_RUNTIME_LOOP=true
JARVIS_ENABLE_DASHBOARD=true
JARVIS_DATA_DIR=/app/data
JARVIS_LOGS_DIR=/app/logs
JARVIS_REPORTS_DIR=/app/reports
JARVIS_QUEUE_STORAGE_PATH=/app/data/task_queue_store.json
JARVIS_SEMANTIC_STORAGE_PATH=/app/data/semantic_memory_store.json
JARVIS_PROCEDURAL_STORAGE_PATH=/app/data/procedural_memory_store.json
JARVIS_GOALS_STORAGE_PATH=/app/data/goals.json
